{
  "name": "alex-shen-personal-site",
  "version": "1.0.0",
  "private": true,
  "description": "中文个人主页与博客静态站，支持 Markdown 内容生成与 GitHub Pages 部署",
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "build": "node scripts/build.mjs",
    "ai:assist": "node scripts/ai-assist.mjs",
    "precommit": "npm run validate && npm run build",
    "setup:hooks": "node scripts/setup-git-hooks.mjs",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "preview": "python3 -m http.server 4173 --directory dist",
    "sitemap": "node scripts/sitemap.mjs",
    "dead-links": "node scripts/dead-link-check.mjs",
    "web-vitals": "node scripts/web-vitals.mjs --url https://alex-shen1121.github.io/personal-blog/",
    "notify": "node scripts/notify-build-failure.mjs"
  }
}
